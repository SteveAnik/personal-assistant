# ── AI Providers ─────────────────────────────────────────────────────────────
# Set ACTIVE_PROVIDER to one of: abacus | openai | anthropic | local
ACTIVE_PROVIDER=abacus

# Abacus AI
ABACUS_API_KEY=
ABACUS_API_URL=https://api.abacus.ai/api/v0
ABACUS_MODEL=claude-sonnet-4-5

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# Local LLM (Ollama or any OpenAI-compatible local server)
LOCAL_LLM_URL=http://ollama:11434/v1
LOCAL_LLM_MODEL=llama3

# ── Embeddings ────────────────────────────────────────────────────────────────
# Provider for generating memory embeddings: abacus | openai | local
EMBEDDING_PROVIDER=abacus
EMBEDDING_MODEL=text-embedding-3-small

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=assistant
POSTGRES_USER=assistant
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://assistant:changeme@postgres:5432/assistant

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=changeme_32char_random_string___
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_BASE_URL=http://n8n:5678

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ── Home Assistant ────────────────────────────────────────────────────────────
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=

# ── Nextcloud ─────────────────────────────────────────────────────────────────
NEXTCLOUD_URL=https://your-nextcloud.local
NEXTCLOUD_USER=
NEXTCLOUD_PASS=

# ── Plex ──────────────────────────────────────────────────────────────────────
PLEX_URL=http://your-plex.local:32400
PLEX_TOKEN=

# ── Proxmox ───────────────────────────────────────────────────────────────────
PROXMOX_URL=https://your-proxmox.local:8006
PROXMOX_API_TOKEN=

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_SECRET_KEY=changeme_agent_secret
AGENT_PORT=8000
